# ──────────────────────────────────────────────────────────────────────────────
# FPL Intelligence Engine — Environment Variables
#
# LOCAL DEV: cp .env.example .env  then docker compose up -d
# RAILWAY:   Set variables in Railway Variables tab — see DEPLOY_CHECKLIST.md B2
#            Do NOT paste this file into Railway.
# ──────────────────────────────────────────────────────────────────────────────


# ── App (required) ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3001
SECRET_KEY=change-me-minimum-32-chars-for-production
ADMIN_TOKEN=change-me-admin-token

# ── Database ───────────────────────────────────────────────────────────────────
# Local dev (outside Docker): port 5433 (mapped by docker-compose)
# Railway: leave unset — PGHOST/PGPORT/etc. injected by PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/fpl_intelligence
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────────
# Local dev (outside Docker): port 6380 (mapped by docker-compose)
# Railway: leave unset — REDIS_PUBLIC_URL injected by Redis plugin
REDIS_URL=redis://localhost:6380/0
JOB_QUEUE_KEY=jobs:queue

# ── FPL settings ───────────────────────────────────────────────────────────────
# FPL_TEAM_ID: system-level fallback only. Users provide their own team_id via API.
FPL_TEAM_ID=0
UNDERSTAT_SEASON=2025
USER_CAP=500
ANONYMOUS_SESSION_TTL_HOURS=24
ANALYSIS_CACHE_TTL_SECONDS=60
PREDICTION_CACHE_TTL_SECONDS=600
FIXTURE_CACHE_TTL_SECONDS=3600
MAX_REQUESTS_PER_MINUTE=120
MAX_HEAVY_REQUESTS_PER_DAY=10
MAX_REGISTRATIONS_PER_HOUR=30
MAX_SESSIONS_PER_HOUR=100
FEATURE_DRIFT_THRESHOLD=0.2
DECISION_ENGINE_MODE=shadow
DEFAULT_RISK_PROFILE=balanced
DECISION_ENGINE_FREEZE_SNAPSHOTS=true

# ── SendGrid (Email) ────────────────────────────────────────────────────────────
# Free tier: 100 emails/day — sufficient for 500 users (weekly digest = 500 emails/week)
# Get key at: https://sendgrid.com → Settings → API Keys
# Verify your sender email in SendGrid first.
# Leave empty → email features silently disabled, no errors.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=fpl@yourdomain.com
NOTIFICATION_TO_EMAIL=your@email.com
ADMIN_ALERT_EMAIL=admin@yourdomain.com

# ── Reddit (PRAW) ──────────────────────────────────────────────────────────────
# Free, no rate limit concerns at our scale. Runs once/day in the data pipeline.
# Create app at: https://www.reddit.com/prefs/apps (type: script)
# Leave empty → Reddit news feature disabled, no errors.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FPLIntelligenceBot/1.0 by u/your_username

# ── The Odds API ───────────────────────────────────────────────────────────────
# Free tier: 500 req/month. We use ~4 req/week (once per gameweek).
# Leave empty → system falls back to team-strength model automatically.
# Get key at: https://the-odds-api.com
ODDS_API_KEY=

# ── Competition Fixtures (UCL / FA Cup / Europa League) ────────────────────────
# Free tier: 10 req/min. We use 1 req/day. Improves rotation_risk predictions.
# Leave empty → rotation risk uses simpler model, no errors.
# Get key at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# ── Twilio WhatsApp ────────────────────────────────────────────────────────────
# Pre-deadline alerts via WhatsApp. Free sandbox available.
# Leave empty → WhatsApp alerts disabled, no errors.
# Get at: https://www.twilio.com/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+44XXXXXXXXXX
