# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3001
SECRET_KEY=change-me-minimum-32-chars-for-production
ADMIN_TOKEN=change-me-admin-token

# ── Database ───────────────────────────────────────────────────────────────────
# For local dev (outside Docker): use port 5433 (mapped from docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/fpl_intelligence
POSTGRES_PASSWORD=changeme

# ── Redis ──────────────────────────────────────────────────────────────────────
# For local dev: port 6380 (mapped from docker-compose)
REDIS_URL=redis://localhost:6380/0
JOB_QUEUE_KEY=jobs:queue

# ── FPL ───────────────────────────────────────────────────────────────────────
# Your FPL team ID — find it in the URL at fantasy.premierleague.com/entry/{ID}/event/1
FPL_TEAM_ID=your_fpl_team_id_here
USER_CAP=500
ANONYMOUS_SESSION_TTL_HOURS=24
ANALYSIS_CACHE_TTL_SECONDS=60
PREDICTION_CACHE_TTL_SECONDS=600
FIXTURE_CACHE_TTL_SECONDS=3600
MAX_REQUESTS_PER_MINUTE=120
MAX_HEAVY_REQUESTS_PER_DAY=10
# Per-hour throttles — protect against launch-day thundering herd.
# Increase after traffic stabilises. Both cap globally (not per-IP).
MAX_REGISTRATIONS_PER_HOUR=30
MAX_SESSIONS_PER_HOUR=100
FEATURE_DRIFT_THRESHOLD=0.2
DECISION_ENGINE_MODE=shadow
DEFAULT_RISK_PROFILE=balanced
DECISION_ENGINE_FREEZE_SNAPSHOTS=true

# ── Understat ──────────────────────────────────────────────────────────────────
# No auth required — public scraping. Season year (e.g. 2025 = 2025/26 season)
UNDERSTAT_SEASON=2025

# ── Reddit (PRAW) ─────────────────────────────────────────────────────────────
# Create a Reddit app at: https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FPLIntelligenceBot/1.0 by u/your_username

# ── The Odds API ───────────────────────────────────────────────────────────────
# Free tier: 500 req/month — get key at https://the-odds-api.com
# Leave empty to skip odds fetching (system falls back to team strength)
ODDS_API_KEY=

# ── SendGrid (Email) ───────────────────────────────────────────────────────────
# Weekly FPL intelligence email. Leave empty to disable emails.
# Get key at: https://sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=fpl@yourdomain.com
NOTIFICATION_TO_EMAIL=your@email.com
# Receives pipeline failure alerts (retrain crash, oracle fail, etc). Leave empty to disable.
ADMIN_ALERT_EMAIL=admin@yourdomain.com

# ── Competition Fixtures (UCL / FA Cup / Europa League) ────────────────────────
# Optional. If set, UCL + FA Cup fixtures are fetched from football-data.org to
# improve rotation_risk predictions (players whose team has midweek European/Cup
# game have higher rotation risk → lower predicted_minutes).
# Get free key at: https://www.football-data.org/client/register (free tier: 10 req/min)
FOOTBALL_DATA_API_KEY=

# ── Twilio WhatsApp ────────────────────────────────────────────────────────────
# Pre-deadline WhatsApp alerts. Leave empty to disable.
# Get at: https://www.twilio.com/whatsapp (sandbox available free)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+44XXXXXXXXXX
